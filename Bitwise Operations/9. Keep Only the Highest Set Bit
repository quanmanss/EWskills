#include <stdio.h>
#include <stdint.h>

// Complete the function
uint16_t highest_set_bit(uint16_t reg) {
 
    if (reg == 0) return 0;
    unint16 result = 1U << 15;
    if((result & reg) ==0) result >>= 1;
    return result;

}

int main() {
    uint16_t reg;
    scanf("%hu", &reg);

    uint16_t result = highest_set_bit(reg);
    printf("%hu", result);
    return 0;
}
